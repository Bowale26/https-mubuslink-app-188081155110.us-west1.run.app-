{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["free", "pro", "team", "admin"] },
        "subscriptionStatus": { "type": "string", "enum": ["none", "trialing", "active", "canceled", "past_due"] },
        "trialEndDate": { "type": "string", "format": "date-time" },
        "planId": { "type": "string" },
        "stripeCustomerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Workspace": {
      "title": "Workspace",
      "description": "A workspace for organizing projects",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "settings": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "ownerId"]
    },
    "Website": {
      "title": "Website",
      "description": "A website project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "workspaceId": { "type": "string" },
        "name": { "type": "string" },
        "domain": { "type": "string" },
        "pages": { "type": "array", "items": { "type": "object" } },
        "theme": { "type": "object" },
        "isPublished": { "type": "boolean" },
        "publishedUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "workspaceId", "name"]
    },
    "Asset": {
      "title": "Asset",
      "description": "Image, video, or font asset",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "workspaceId": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video", "icon", "font"] },
        "url": { "type": "string" },
        "source": { "type": "string", "enum": ["ai-generated", "stock", "uploaded"] },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "url", "type"]
    },
    "Chatbot": {
      "title": "Chatbot",
      "description": "AI Chatbot configuration",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "websiteId": { "type": "string" },
        "name": { "type": "string" },
        "config": { "type": "object" },
        "knowledgeBase": { "type": "array", "items": { "type": "object" } },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "websiteId", "name"]
    },
    "Translation": {
      "title": "Translation",
      "description": "Website page translation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "websiteId": { "type": "string" },
        "pageId": { "type": "string" },
        "language": { "type": "string" },
        "content": { "type": "object" },
        "status": { "type": "string", "enum": ["pending", "completed", "needs_review"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "websiteId", "pageId", "language"]
    },
    "AnalyticsEvent": {
      "title": "AnalyticsEvent",
      "description": "Tracking event for website performance",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "websiteId": { "type": "string" },
        "eventType": { "type": "string" },
        "pagePath": { "type": "string" },
        "visitorId": { "type": "string" },
        "metadata": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "websiteId", "eventType"]
    },
    "MaintenanceLog": {
      "title": "MaintenanceLog",
      "description": "System maintenance action log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "actionType": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["success", "warning", "error"] },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "actionType", "status"]
    },
    "Mail": {
      "title": "Mail",
      "description": "Email to be sent via Trigger Email extension",
      "type": "object",
      "properties": {
        "to": { "type": "string" },
        "message": {
          "type": "object",
          "properties": {
            "subject": { "type": "string" },
            "html": { "type": "string" },
            "text": { "type": "string" }
          }
        }
      },
      "required": ["to", "message"]
    },
    "GlobalStats": {
      "title": "GlobalStats",
      "description": "Aggregated system KPIs and statistics",
      "type": "object",
      "properties": {
        "activeWebsites": { "type": "number" },
        "totalVisitors": { "type": "number" },
        "aiWordsWritten": { "type": "number" },
        "botConversations": { "type": "number" },
        "trialConversions": { "type": "number" },
        "totalRevenue": { "type": "number" },
        "totalSignups": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/global_stats/{docId}": {
      "schema": "GlobalStats",
      "description": "Global statistics and KPIs"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/workspaces/{workspaceId}": {
      "schema": "Workspace",
      "description": "Workspaces for organizing projects"
    },
    "/workspaces/{workspaceId}/members/{userId}": {
      "schema": { "$ref": "User" },
      "description": "Workspace members and roles"
    },
    "/websites/{websiteId}": {
      "schema": "Website",
      "description": "Website projects"
    },
    "/assets/{assetId}": {
      "schema": "Asset",
      "description": "Media assets"
    },
    "/chatbots/{chatbotId}": {
      "schema": "Chatbot",
      "description": "AI Chatbots"
    },
    "/translations/{translationId}": {
      "schema": "Translation",
      "description": "Website translations"
    },
    "/analytics_events/{eventId}": {
      "schema": "AnalyticsEvent",
      "description": "Analytics tracking data"
    },
    "/maintenance_logs/{logId}": {
      "schema": "MaintenanceLog",
      "description": "System maintenance logs"
    },
    "/mail/{mailId}": {
      "schema": "Mail",
      "description": "Outbound emails"
    },
    "/customers/{userId}": {
      "schema": "object",
      "description": "Stripe customer data managed by the extension"
    },
    "/customers/{userId}/checkout_sessions/{sessionId}": {
      "schema": "object",
      "description": "Stripe checkout sessions created by the app"
    },
    "/customers/{userId}/portal_sessions/{sessionId}": {
      "schema": "object",
      "description": "Stripe customer portal sessions created by the app"
    },
    "/customers/{userId}/subscriptions/{subscriptionId}": {
      "schema": "object",
      "description": "Stripe subscription data synced by the extension"
    },
    "/products/{productId}": {
      "schema": "object",
      "description": "Stripe products synced by the extension"
    },
    "/products/{productId}/prices/{priceId}": {
      "schema": "object",
      "description": "Stripe prices synced by the extension"
    }
  }
}
