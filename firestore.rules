rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Blanket permission for all authenticated users as requested
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Explicit public read for Stripe Products/Prices (Required for Guest View)
    match /products/{id} {
      allow read: if true;
      match /prices/{id} {
        allow read: if true;
      }
    }
  }
}
